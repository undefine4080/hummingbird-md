{
  "name": "hummingbird-md",
  "displayName": "Hummingbird MD",
  "description": "专业的 Markdown 阅读器，支持目录导航、主题切换、字体调整、图片查看器和 Mermaid 图表渲染",
  "version": "0.1.0",
  "publisher": "hummingbird-md",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Readers"
  ],
  "keywords": [
    "markdown",
    "reader",
    "mermaid",
    "toc"
  ],
  "activationEvents": [
    "onCommand:hummingbird-md.openReader",
    "onView:hummingbird-md.tocView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hummingbird-md.openReader",
        "title": "Preview in Hummingbird MD",
        "icon": "media/icon.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "hummingbird-md.openReader",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "hummingbird-md.openReader",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "hummingbird-md.openReader",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hummingbird-md-toc",
          "title": "Hummingbird MD",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "hummingbird-md-toc": [
        {
          "type": "webview",
          "id": "hummingbird-md.tocView",
          "name": "dashboard"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.cjs --production",
    "watch": "node esbuild.cjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "markdown-it": "^14.0.0",
    "mermaid": "^11.14.0",
    "shiki": "^4.0.2"
  }
}
